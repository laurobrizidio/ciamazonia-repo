    END
  END oe_n
  PIN row_addr[0]
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.180700 ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 44.740 0.400 45.140 ;
    END
  END row_addr[0]
  PIN row_addr[1]
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.180700 ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 43.900 0.400 44.300 ;
    END
  END row_addr[1]
  PIN we_n
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.180700 ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 43.060 0.400 43.460 ;
    END
  END we_n
  OBS
      LAYER GatPoly ;
        RECT 5.760 14.970 62.400 71.970 ;
      LAYER Metal1 ;
        RECT 5.760 14.900 62.400 72.040 ;
      LAYER Metal2 ;
        RECT 6.135 14.975 62.980 71.965 ;
      LAYER Metal3 ;
        RECT 0.400 62.990 68.140 71.920 ;
        RECT 0.610 62.170 68.140 62.990 ;
        RECT 0.400 56.270 68.140 62.170 ;
        RECT 0.610 55.450 68.140 56.270 ;
        RECT 0.400 45.350 68.140 55.450 ;
        RECT 0.610 44.530 67.930 45.350 ;
        RECT 0.400 44.510 68.140 44.530 ;
        RECT 0.610 43.690 67.930 44.510 ;
        RECT 0.400 43.670 68.140 43.690 ;
        RECT 0.610 42.850 68.140 43.670 ;
        RECT 0.400 42.830 68.140 42.850 ;
        RECT 0.610 42.010 68.140 42.830 ;
        RECT 0.400 31.910 68.140 42.010 ;
        RECT 0.400 31.090 67.930 31.910 ;
        RECT 0.400 21.830 68.140 31.090 ;
