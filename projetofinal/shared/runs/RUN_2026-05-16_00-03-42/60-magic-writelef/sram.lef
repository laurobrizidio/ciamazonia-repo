    USE SIGNAL ;
    ANTENNAGATEAREA 1.450800 ;
    PORT
      LAYER Metal3 ;
        RECT 68.140 21.220 68.540 21.620 ;
    END
  END clk
  PIN col_addr[0]
    DIRECTION INPUT ;
