VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO sram
  CLASS BLOCK ;
  FOREIGN sram ;
  ORIGIN 0.000 0.000 ;
  SIZE 68.540 BY 87.260 ;
  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER TopMetal1 ;
        RECT 24.460 14.490 26.660 72.040 ;
    END
    PORT
      LAYER TopMetal2 ;
        RECT 5.760 33.820 62.400 36.020 ;
    END
  END VGND
  PIN VPWR
    DIRECTION INOUT ;
